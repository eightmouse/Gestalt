{
  "name": "gestalt-archive",
  "version": "1.3.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "check": "tsc --noEmit",
    "audit": "pnpm audit --audit-level high",
    "install:safe": "pnpm install --ignore-scripts",
    "content:new": "node scripts/new-entry.mjs",
    "content:check": "node scripts/validate-content.mjs"
  },
  "dependencies": {
    "framer-motion": "12.23.12",
    "lucide-react": "0.542.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "react-server-dom-parcel": "19.2.6",
      "react-server-dom-turbopack": "19.2.6",
      "react-server-dom-webpack": "19.2.6"
    },
    "onlyBuiltDependencies": []
  }
}
